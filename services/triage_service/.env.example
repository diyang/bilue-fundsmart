# FundSmart triage service runtime settings.
#
# Copy this file to services/triage_service/.env for local uvicorn and Docker Compose.
# TRIAGE_LLM_* values override REASONING_LLM_* values when both are set.

REASONING_LLM_MODEL=gpt-5.5
REASONING_LLM_REASONING_EFFORT=medium
UTILITY_LLM_MODEL=gpt-5.4-mini
UTILITY_LLM_REASONING_EFFORT=medium

# Optional explicit triage overrides.
# TRIAGE_LLM_MODEL=gpt-5.5
# TRIAGE_LLM_REASONING_EFFORT=medium

# Optional service settings.
# TRIAGE_SERVICE_API_KEY=
# TRIAGE_SERVICE_LOG_LEVEL=INFO
# TRIAGE_DATABASE_URL=postgresql+psycopg://fundsmart:fundsmart@localhost:5433/fundsmart
# TRIAGE_DATABASE_AUTO_CREATE=true
