# FundSmart synthetic data generation service runtime settings.
#
# Copy this file to services/sythetic_data_generation/.env for local uvicorn
# and Docker Compose.
# SYNTHETIC_DATA_LLM_* values override REASONING_LLM_* values when both are set.

REASONING_LLM_MODEL=gpt-5.5
REASONING_LLM_REASONING_EFFORT=medium

# Optional explicit synthetic generation overrides.
# SYNTHETIC_DATA_LLM_MODEL=gpt-5.5
# SYNTHETIC_DATA_LLM_REASONING_EFFORT=medium

# Optional service settings.
# SYNTHETIC_DATA_SERVICE_API_KEY=
# SYNTHETIC_DATA_SERVICE_LOG_LEVEL=INFO
